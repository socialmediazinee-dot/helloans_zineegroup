# Resend API Key for sending emails
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=your_resend_api_key_here

# One inbox for all form submissions (optional; when set, all forms send here)
NOTIFY_EMAIL=your-email@gmail.com

# Per-form fallbacks (used when NOTIFY_EMAIL is not set)
PARTNER_EMAIL=info@zineegroup.com
CONTACT_EMAIL=info@zineegroup.com
LOAN_EMAIL=info@zineegroup.com
CIBIL_EMAIL=info@zineegroup.com
REVIEW_EMAIL=info@zineegroup.com

# From email address (must be verified in Resend)
# For development, you can use onboarding@resend.dev
# For production, use your verified domain email
FROM_EMAIL=onboarding@resend.dev
# RESEND_FROM_EMAIL=noreply@yourdomain.com

# OTP verification (for forms with mobile number)
# --- 2Factor.in (India, recommended) ---
# Get API key from https://2factor.in/CP/Dashboard_list.php
# When set, OTP is sent via 2Factor and verification is done by their API (OTP correctness checked on their side).
TWO_FACTOR_API_KEY=your_2factor_api_key_here

# Google Sheets — publish each sheet to web as CSV, then paste the full URL here
# How: open sheet → File → Share → Publish to web → CSV → copy URL
GOOGLE_SHEET_STOCKS_CSV=https://docs.google.com/spreadsheets/d/e/YOUR_STOCKS_SHEET/pub?output=csv
GOOGLE_SHEET_REVIEWS_CSV=https://docs.google.com/spreadsheets/d/e/YOUR_REVIEWS_SHEET/pub?output=csv

# Bank requirements per loan category (columns: loan_category, bank_name, requirement_1 ... requirement_6)
GOOGLE_SHEET_REQUIREMENTS_CSV=https://docs.google.com/spreadsheets/d/e/2PACX-1vTBTYapa8vtDnyGX_dO3FRHWBFbTmjfgLD_1ocioCSaltMIsBxd5npMISBa2fQn2maleU7ibQ6DsjG0/pub?output=csv

# Loan comparison sheets (columns: Bank Name, ID, Logo Path, Type, Interest Rate, Processing Fee,
#   Min Amount, Max Amount, Min Tenure Yrs, Max Tenure Yrs, Description, Eligibility, Features)
# Type = "bank" (for the 2 bank slots) or "nbfc" (for the Over Draft slot)
# Features column uses pipe (|) separator, e.g. "Quick approval|No prepayment charges|Flexible EMI"
GOOGLE_SHEET_PERSONAL_LOANS_CSV=https://docs.google.com/spreadsheets/d/e/2PACX-1vSVZtq-p94qf7uuhopC_QSrb9GJm7Om2zb3deEZXOgQam-DPnlIExcXffKlEuhiPwUlYKutlUBCOwCu/pub?output=csv
GOOGLE_SHEET_BUSINESS_LOANS_CSV=https://docs.google.com/spreadsheets/d/e/2PACX-1vSgdmqFnlmGTF0uyLVtAHR5W-P4mnJ5m1XDL0M4QUn8UDk_lJxludnm0PBnP95OCZrggCDQbo85X1Yh/pub?output=csv
# Ticker only: Home Loan & LAP. 4 columns: Bank Name, Type (bank|nbfc), Interest Rate, Product (Home Loan | Loan Against Property).
GOOGLE_SHEET_HOME_PROPERTY_LOANS_CSV=https://docs.google.com/spreadsheets/d/e/2PACX-1vRj9pq5dOddEXBLezzAy-4SYmA9e6ZSs2uxNUZRHIJYLffltGKZCORQ0l0QltM5XFFKNKPiPp0R3mWN/pub?output=csv

# --- Other providers (used only if TWO_FACTOR_API_KEY is not set) ---
# OTP_SMS_PROVIDER=msg91
# MSG91_AUTH_KEY=your_msg91_auth_key
# MSG91_SENDER_ID=ZINEEG
# OTP_SMS_PROVIDER=twilio
# TWILIO_ACCOUNT_SID=your_account_sid
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_PHONE_NUMBER=+1234567890
